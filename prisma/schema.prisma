generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContactChannel {
  WHATSAPP
  WECHAT
  EMAIL
  TELEGRAM
  OTHER
}

enum ProductStatus {
  TESTING
  ACTIVE
  WINNER
  PAUSED
  CLOSED
}

enum OrderStatus {
  PAID
  WAITING_SUPPLIER_PURCHASE
  PURCHASED_FROM_SUPPLIER
  SHIPPED
  DELIVERED
  DELAYED
  ISSUE
  REFUNDED
  CANCELED
}

enum FinancialEntryType {
  INCOME
  EXPENSE
  REFUND
}

enum InvoiceType {
  PURCHASE
  SALE
}

enum InvoiceStatus {
  PENDING
  ISSUED
  PAID
  CANCELED
}

enum SalesChannelProvider {
  TIKTOK_SHOP
}

enum SalesChannelStatus {
  DISCONNECTED
  PENDING
  ACTIVE
  ERROR
}

enum SalesChannelSyncType {
  FULL
  PRODUCTS
  ORDERS
  WEBHOOK
}

enum SalesChannelSyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  ERROR
}

enum FinancialCategory {
  ORDER_REVENUE
  PRODUCT_COST
  SHIPPING_COST
  PLATFORM_FEE
  AD_SPEND
  REFUND
  OPERATING_EXPENSE
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model User {
  id               String           @id @default(cuid()) @db.VarChar(191)
  name             String
  email            String           @unique
  passwordHash     String?          @map("password_hash")
  suppliers        Supplier[]
  products         Product[]
  orders           Order[]
  financialEntries FinancialEntry[]
  invoices         Invoice[]
  salesChannels    SalesChannelConnection[]
  tasks            Task[]
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("users")
}

model Supplier {
  id               String          @id @default(cuid()) @db.VarChar(191)
  userId           String          @map("user_id") @db.VarChar(191)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  contactName      String?         @map("contact_name")
  contactChannel   ContactChannel? @map("contact_channel")
  region           String?
  avgShippingDays  Int?            @map("avg_shipping_days")
  reliabilityScore Decimal?        @map("reliability_score") @db.Decimal(3, 2)
  issueRate        Decimal?        @map("issue_rate") @db.Decimal(5, 2)
  notes            String?         @db.Text
  products         Product[]
  orders           Order[]
  invoices         Invoice[]
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, name])
  @@map("suppliers")
}

model Product {
  id              String        @id @default(cuid()) @db.VarChar(191)
  userId          String        @map("user_id") @db.VarChar(191)
  supplierId      String        @map("supplier_id") @db.VarChar(191)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  name            String
  sku             String
  category        String?
  storeLink       String?       @map("store_link")
  supplierLink    String?       @map("supplier_link")
  costPrice       Decimal       @map("cost_price") @db.Decimal(10, 2)
  shippingCost    Decimal       @map("shipping_cost") @db.Decimal(10, 2)
  salePrice       Decimal       @map("sale_price") @db.Decimal(10, 2)
  estimatedMargin Decimal       @map("estimated_margin") @db.Decimal(10, 2)
  status          ProductStatus
  notes           String?       @db.Text
  orders          Order[]
  invoiceItems    InvoiceProduct[]
  salesChannelLinks SalesChannelProductLink[]
  tasks           Task[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([userId, sku])
  @@index([userId, status])
  @@index([supplierId])
  @@map("products")
}

model Order {
  id                    String           @id @default(cuid()) @db.VarChar(191)
  userId                String           @map("user_id") @db.VarChar(191)
  productId             String           @map("product_id") @db.VarChar(191)
  supplierId            String           @map("supplier_id") @db.VarChar(191)
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  product               Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplier              Supplier         @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  orderNumber           String           @map("order_number")
  customerName          String           @map("customer_name")
  customerEmail         String?          @map("customer_email")
  saleAmount            Decimal          @map("sale_amount") @db.Decimal(10, 2)
  totalCost             Decimal          @map("total_cost") @db.Decimal(10, 2)
  status                OrderStatus
  trackingCode          String?          @map("tracking_code")
  purchaseDate          DateTime         @map("purchase_date")
  estimatedDeliveryDate DateTime?        @map("estimated_delivery_date")
  deliveredDate         DateTime?        @map("delivered_date")
  notes                 String?          @db.Text
  financialEntries      FinancialEntry[]
  invoices              Invoice[]
  salesChannelLinks     SalesChannelOrderLink[]
  tasks                 Task[]
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  @@unique([userId, orderNumber])
  @@index([userId, status])
  @@index([productId])
  @@index([supplierId])
  @@map("orders")
}

model FinancialEntry {
  id            String             @id @default(cuid()) @db.VarChar(191)
  userId        String             @map("user_id") @db.VarChar(191)
  orderId       String?            @map("order_id") @db.VarChar(191)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  order         Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type          FinancialEntryType
  category      FinancialCategory
  amount        Decimal            @db.Decimal(10, 2)
  referenceDate DateTime           @map("reference_date")
  description   String?            @db.Text
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([userId, type, referenceDate])
  @@index([orderId])
  @@map("financial_entries")
}

model Invoice {
  id         String        @id @default(cuid()) @db.VarChar(191)
  userId     String        @map("user_id") @db.VarChar(191)
  orderId    String?       @map("order_id") @db.VarChar(191)
  supplierId String?       @map("supplier_id") @db.VarChar(191)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order      Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  supplier   Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  number     String
  series     String?
  accessKey  String?       @map("access_key")
  type       InvoiceType
  status     InvoiceStatus
  issueDate  DateTime      @map("issue_date")
  dueDate    DateTime?     @map("due_date")
  amount     Decimal       @db.Decimal(10, 2)
  taxAmount  Decimal?      @map("tax_amount") @db.Decimal(10, 2)
  xmlFileName String?      @map("xml_file_name")
  xmlContent String?       @map("xml_content") @db.Text
  notes      String?       @db.Text
  invoiceProducts InvoiceProduct[]
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@index([userId, status, issueDate])
  @@index([userId, type, status])
  @@index([orderId])
  @@index([supplierId])
  @@map("invoices")
}

model InvoiceProduct {
  id             String   @id @default(cuid()) @db.VarChar(191)
  invoiceId      String   @map("invoice_id") @db.VarChar(191)
  productId      String   @map("product_id") @db.VarChar(191)
  itemNumber     String?  @map("item_number")
  xmlProductCode String?  @map("xml_product_code")
  xmlEan         String?  @map("xml_ean")
  description    String
  quantity       Decimal  @db.Decimal(12, 4)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 4)
  lineAmount     Decimal  @map("line_amount") @db.Decimal(10, 2)
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([invoiceId, itemNumber])
  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_products")
}

model SalesChannelConnection {
  id                    String                @id @default(cuid()) @db.VarChar(191)
  userId                String                @map("user_id") @db.VarChar(191)
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              SalesChannelProvider
  status                SalesChannelStatus    @default(PENDING)
  displayName           String                @map("display_name")
  shopId                String?               @map("shop_id")
  shopCipher            String?               @map("shop_cipher")
  shopCode              String?               @map("shop_code")
  shopName              String?               @map("shop_name")
  shopRegion            String?               @map("shop_region")
  accessToken           String?               @map("access_token") @db.Text
  refreshToken          String?               @map("refresh_token") @db.Text
  accessTokenExpiresAt  DateTime?             @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime?             @map("refresh_token_expires_at")
  scopes                String?               @db.Text
  stateToken            String?               @map("state_token")
  stateExpiresAt        DateTime?             @map("state_expires_at")
  lastSyncedAt          DateTime?             @map("last_synced_at")
  lastProductsSyncAt    DateTime?             @map("last_products_sync_at")
  lastOrdersSyncAt      DateTime?             @map("last_orders_sync_at")
  lastWebhookAt         DateTime?             @map("last_webhook_at")
  lastError             String?               @map("last_error") @db.Text
  metadata              String?               @db.Text
  syncRuns              SalesChannelSyncRun[]
  productLinks          SalesChannelProductLink[]
  orderLinks            SalesChannelOrderLink[]
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  @@unique([userId, provider])
  @@index([provider, status])
  @@index([userId, status])
  @@map("sales_channel_connections")
}

model SalesChannelSyncRun {
  id            String                @id @default(cuid()) @db.VarChar(191)
  connectionId  String                @map("connection_id") @db.VarChar(191)
  connection    SalesChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  type          SalesChannelSyncType
  status        SalesChannelSyncStatus
  summary       String?
  payload       String?               @db.Text
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@index([connectionId, createdAt])
  @@map("sales_channel_sync_runs")
}

model SalesChannelProductLink {
  id                String                 @id @default(cuid()) @db.VarChar(191)
  connectionId      String                 @map("connection_id") @db.VarChar(191)
  productId         String                 @map("product_id") @db.VarChar(191)
  externalProductId String                 @map("external_product_id")
  externalSkuId     String?                @map("external_sku_id")
  externalSkuKey    String                 @default("") @map("external_sku_key")
  externalSku       String?                @map("external_sku")
  title             String?
  rawPayload        String?                @map("raw_payload") @db.Text
  lastSeenAt        DateTime               @default(now()) @map("last_seen_at")
  connection        SalesChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  product           Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  @@unique([connectionId, externalProductId, externalSkuKey])
  @@index([productId])
  @@index([connectionId, lastSeenAt])
  @@map("sales_channel_product_links")
}

model SalesChannelOrderLink {
  id              String                 @id @default(cuid()) @db.VarChar(191)
  connectionId    String                 @map("connection_id") @db.VarChar(191)
  orderId         String                 @map("order_id") @db.VarChar(191)
  externalOrderId String                 @map("external_order_id")
  rawPayload      String?                @map("raw_payload") @db.Text
  lastSeenAt      DateTime               @default(now()) @map("last_seen_at")
  connection      SalesChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  order           Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@unique([connectionId, externalOrderId])
  @@index([orderId])
  @@index([connectionId, lastSeenAt])
  @@map("sales_channel_order_links")
}

model Task {
  id               String       @id @default(cuid()) @db.VarChar(191)
  userId           String       @map("user_id") @db.VarChar(191)
  relatedOrderId   String?      @map("related_order_id") @db.VarChar(191)
  relatedProductId String?      @map("related_product_id") @db.VarChar(191)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedOrder     Order?       @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)
  relatedProduct   Product?     @relation(fields: [relatedProductId], references: [id], onDelete: SetNull)
  title            String
  description      String?      @db.Text
  priority         TaskPriority
  status           TaskStatus
  assigneeName     String?      @map("assignee_name")
  dueDate          DateTime?    @map("due_date")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([userId, status, dueDate])
  @@index([relatedOrderId])
  @@index([relatedProductId])
  @@map("tasks")
}
