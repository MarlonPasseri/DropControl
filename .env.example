POSTGRES_DB="dropship_control"
POSTGRES_USER="dropship"
POSTGRES_PASSWORD="troque-esta-senha-local"
POSTGRES_PORT="5432"

# Local Docker:
DATABASE_URL="postgresql://dropship:troque-esta-senha-local@localhost:5432/dropship_control?schema=public"

# Cloud SQL public IP, somente se o IP do app estiver autorizado e SSL estiver habilitado.
# Para desenvolvimento direto por IP publico com node-postgres:
# DATABASE_URL="postgresql://dropcontrol_app:SENHA_FORTE@IP_PUBLICO:5432/dropcontrol?schema=public&sslmode=require&uselibpqcompat=true"

# Producao/Cloud Run: usado pelo app e pelo Cloud Run Job de migrations.
DB_USER="dropcontrol"
DB_PASS="SENHA_DO_USUARIO_DROPCONTROL"
DB_NAME="dropcontrol"
INSTANCE_UNIX_SOCKET="/cloudsql/PROJECT_ID:REGION:INSTANCE_ID"

# Producao/Cloud Run: bucket privado para fotos de perfil.
PROFILE_IMAGE_BUCKET=""

AUTH_SECRET="gere-com-npx-auth-secret"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
APP_URL="http://localhost:3000"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Dropship Control <no-reply@localhost>"
TIKTOK_SHOP_APP_KEY=""
TIKTOK_SHOP_APP_SECRET=""
TIKTOK_SHOP_AUTH_URL="https://auth.tiktok-shops.com/oauth/authorize"
TIKTOK_SHOP_TOKEN_URL="https://auth.tiktok-shops.com/api/v2/token/get"
TIKTOK_SHOP_API_BASE_URL="https://open-api.tiktokglobalshop.com"
TIKTOK_SHOP_PRODUCTS_PATH="/product/202309/products/search"
TIKTOK_SHOP_ORDERS_PATH="/order/202309/orders/search"
TIKTOK_SHOP_SHOP_INFO_PATH="/authorization/202309/shops"
TIKTOK_SHOP_SCOPES="seller.product.basic,seller.order.info,seller.shop.info"
TIKTOK_SHOP_TOKEN_GRANT_TYPE="authorized_code"
TIKTOK_SHOP_REFRESH_GRANT_TYPE="refresh_token"
TIKTOK_SHOP_TOKEN_SECRET="minha-chave-super-segura"
TIKTOK_SHOP_WEBHOOK_SECRET=""
